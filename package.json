{
  "name": "framer-v4-pipeline-v2",
  "version": "0.20.0",
  "description": "Standalone Framer to Elementor V4 pre-build pipeline scripts",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test tests/pipeline.test.js tests/lib/*.test.js tests/inspect-v4-schemas.test.js tests/phase-1-bug-2-regression.test.js tests/sprint19-fixes.test.js",
    "test:e2e": "node --test tests/e2e.test.js",
    "test:all": "node --test tests/pipeline.test.js tests/lib/*.test.js tests/sprint19-fixes.test.js && node --test tests/e2e.test.js && node --test tests/integration.test.js",
    "test:visual": "node --test tests/visual-regression.test.js",
    "test:integration": "node --test tests/integration.test.js",
    "test:phase4": "node --test tests/lib/elementor-version.test.js tests/lib/wp-theme.test.js tests/lib/pro-fallback.test.js",
    "test:phase5": "node --test tests/lib/framer-cache.test.js tests/lib/asset-batch-uploader.test.js tests/lib/pipeline-waves.test.js",
    "test:lib": "node --test tests/lib/*.test.js",
    "framer-cache:stats": "node -e \"import('./scripts/lib/framer-cache.ts').then(m => console.log(JSON.stringify(m.getFramerCacheStats(), null, 2)))\"",
    "framer-cache:clear": "node -e \"import('./scripts/lib/framer-cache.ts').then(m => m.clearFramerCache())\"",
    "test:bridge": "node --import tsx scripts/lib/mcp-bridge.ts --self-test",
    "validate": "node --import tsx scripts/framer-pre-build-validate.ts",
    "preflight-check": "node --import tsx scripts/preflight-check.ts",
    "preflight:experiments": "node --import tsx scripts/preflight/ensure-elementor-experiments.ts",
    "preflight:experiments-dry": "node --import tsx scripts/preflight/ensure-elementor-experiments.ts --dry-run",
    "preflight:unframer": "node --import tsx scripts/preflight/check-unframer-connectivity.ts",
    "preflight:xml-match": "node --import tsx scripts/preflight/verify-xml-project-match.ts",
    "schema-validate": "node --import tsx scripts/validate-v4-tree.ts",
    "check-binding": "node --import tsx scripts/verify-build-binding.ts",
    "token-extract": "node --import tsx scripts/design-token-extractor.ts",
    "gc-generate": "node --import tsx scripts/generate-global-classes.ts",
    "gc-execute": "node --import tsx scripts/generate-global-classes.ts --execute",
    "cross-validate": "node --import tsx scripts/cross-validate-sources.ts",
    "patch-media": "node --import tsx scripts/patch-v4-tree-media-ids.ts",
    "auto-scale": "node --import tsx scripts/auto-scale-responsive.ts",
    "dependency-graph": "node --import tsx scripts/build-dependency-graph.ts",
    "convert": "node --import tsx scripts/convert-xml-to-v4.ts",
    "asset-queue": "node --import tsx scripts/asset-to-wp-media.ts",
    "asset-upload": "node --import tsx scripts/asset-to-wp-media.ts --execute",
    "export-mcp-plan": "node --import tsx scripts/export-mcp-xml.ts",
    "widget-plan": "node --import tsx scripts/html-to-widget-plan.ts",
    "widget-plan-execute": "node --import tsx scripts/html-to-widget-plan.ts --execute",
    "sync-schema": "node --import tsx scripts/sync-schema.ts",
    "parallel": "node --import tsx scripts/parallel-pre-build.ts",
    "test:schema": "node --import tsx scripts/sync-schema.ts --validate",
    "visual-qa": "node --import tsx scripts/visual-qa.ts",
    "visual-qa-a11y": "node --import tsx scripts/visual-qa.ts --a11y",
    "check-v4": "node --import tsx scripts/check-v4-requirements.ts",
    "check-v4-auto": "node --import tsx scripts/check-v4-requirements.ts --auto-call",
    "dedup-qa": "node --import tsx scripts/deduplicate-visual-qa.ts",
    "apply-gv-ids": "node --import tsx scripts/design-token-extractor.ts --apply-response",
    "post-build-qa": "node --import tsx scripts/run-post-build-qa.ts",
    "section-compare": "node --import tsx scripts/section-compare.ts",
    "compare:hero": "node --import tsx scripts/section-compare.ts --framer-url ${FRAMER_PREVIEW_URL:?Set FRAMER_PREVIEW_URL in .env} --elementor-url ${WP_PREVIEW_URL:?Set WP_PREVIEW_URL in .env} --section hero --above-fold --open",
    "extract-components": "node --import tsx scripts/extract-framer-components.ts",
    "extract-interactions": "node --import tsx scripts/extract-framer-interactions.ts",
    "extract-forms": "node --import tsx scripts/extract-framer-forms.ts",
    "extract-dark-mode": "node --import tsx scripts/extract-framer-dark-mode.ts",
    "extract-animations": "node --import tsx scripts/framer-animation-extractor.ts",
    "auto-fix": "node --import tsx scripts/post-build-auto-fix.ts",
    "inject-code": "node --import tsx scripts/inject-animation-code.ts",
    "inject-animations": "node --import tsx scripts/inject-animation-code.ts --plan animation-plan.json",
    "inject-from-export": "node --import tsx scripts/inject-animation-code.ts --from-framer-export",
    "wizard-batch": "node --import tsx wizard.ts batch",
    "lint:version": "node --import tsx scripts/lint-test-count.ts",
    "measure-quality": "node --import tsx scripts/measure-quality-metrics.ts",
    "test:integration-live": "node --test tests/integration.test.js -- --live",
    "profile-pipeline": "node --import tsx scripts/profile-pipeline.ts",
    "deploy-plugin": "bash novamira-adrianv2/scripts/deploy-plugin.sh",
    "session-init": "node --import tsx scripts/session-init.ts",
    "session-init:update-state": "node --import tsx scripts/session-init.ts --update-session-state",
    "css-fallback": "node --import tsx scripts/css-fallback-extractor.ts",
    "css-fallback:url": "node --import tsx scripts/css-fallback-extractor.ts --url",
    "css-fallback:html": "node --import tsx scripts/css-fallback-extractor.ts --html",
    "responsive": "node --import tsx scripts/integrate-responsive.ts",
    "responsive:with-css": "node --import tsx scripts/integrate-responsive.ts --css",
    "post-build": "node --import tsx scripts/post-build-hook.ts",
    "post-build:qa-only": "node --import tsx scripts/post-build-hook.ts --qa-only",
    "post-build:dry": "node --import tsx scripts/post-build-hook.ts --dry-run"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.1",
    "axe-core": "^4.12.1",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
